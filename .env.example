# Copy to .env and fill in. Used by the headless CLI (scripts/generate_brief.py)
# and the GitHub Actions cron. The Streamlit dashboard reads from
# .streamlit/secrets.toml instead — see .streamlit/secrets.toml.example.
#
# All three credentials are FREE.

# ENTSO-E Transparency Platform — DE day-ahead power.
# Register: https://transparency.entsoe.eu/  → My Account Settings → Generate token
# Note: API access requires a separate email request to transparency@entsoe.eu
#       (subject: "Restful API access"); allow 1–3 business days for confirmation.
ENTSOE_TOKEN=

# GIE AGSI+ — EU gas storage (% full).
# Register: https://agsi.gie.eu/account
# Token visible on the account page immediately after email verification.
AGSI_TOKEN=

# Anthropic — Claude API for the AI desk-note narrative (Haiku 4.5).
# Register: https://console.anthropic.com  → Plans & Billing → Add credit
# Then API Keys → Create Key. Daily run cost: fractions of a cent.
ANTHROPIC_API_KEY=
